# ═══════════════════════════════════════════════════════════════════════════
#  sway config — ported from the Hyprland rice (Debian / Wayland)
#  Style: minimal · hacky · retro. Light transparency, no blur.
#  Reference: man 5 sway
# ═══════════════════════════════════════════════════════════════════════════

### Variables
set $mod Mod4
set $term kitty
set $filemanager thunar
set $menu rofi -show drun -show-icons -theme ~/.config/rofi/config.rasi
set $scripts ~/dotfiles/scripts

# Theme colors (regenerated by theme-switch.sh)
include ~/.config/sway/colors.conf

### Monitors ──────────────────────────────────────────────────────────────
# DP-1  = external 144Hz, primary, left.   eDP-1 = laptop 60Hz, right.
output DP-1  mode 1920x1080@144Hz position 0 0
output eDP-1 mode 1920x1080@60Hz  position 1920 0

# Wallpaper handled by random-wallpaper.sh (swaybg); fallback solid color:
output * background $bg solid_color

### Look & feel ───────────────────────────────────────────────────────────
default_border pixel 2
default_floating_border pixel 2
hide_edge_borders smart
gaps inner 5
gaps outer 8
smart_gaps on
font pango:IosevkaTerm Nerd Font 10

# Light transparency (no blur). Terminal keeps its own opacity on top.
for_window [app_id=".*"] opacity 0.96
for_window [class=".*"]  opacity 0.96

# Borders:           border    background  text  indicator  child_border
client.focused          $accent   $accent   $fg   $accent    $accent
client.focused_inactive $inactive $bg_alt   $fg   $inactive  $inactive
client.unfocused        $inactive $bg       $fg   $inactive  $inactive
client.urgent           $urgent   $urgent   $fg   $urgent    $urgent

### Input ──────────────────────────────────────────────────────────────────
input "type:keyboard" {
    xkb_layout us
}
input "type:touchpad" {
    natural_scroll disabled
    tap enabled
    dwt enabled
}

### Autostart ──────────────────────────────────────────────────────────────
exec mako
exec waybar
exec $scripts/random-wallpaper.sh
exec sh -c '/usr/lib/policykit-1-gnome/polkit-gnome-authentication-agent-1 || /usr/libexec/polkit-gnome-authentication-agent-1'
# Idle: lock at 10min, screen off at 15min, lock before sleep
exec swayidle -w \
    timeout 600  'swaylock -f' \
    timeout 900  'swaymsg "output * power off"' \
    resume       'swaymsg "output * power on"' \
    before-sleep 'swaylock -f'

